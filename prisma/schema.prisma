generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id              String   @id @default(cuid())
  roleIndustry    String
  goals           String
  tone            String
  constraints     String
  preferredFormat String
  dos             String?
  donts           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SessionOutput {
  id                 String   @id @default(cuid())
  profileId          String
  threadId           String
  baseTask           String
  previousOutputJson Json?
  currentOutputJson  Json
  revisionRequest    String?
  rating             String?
  feedback           String?
  createdAt          DateTime @default(now())
}

model SavedVendor {
  id          String   @id @default(cuid())
  userId      String
  name        String
  category    String
  region      String
  websiteUrl  String
  description String
  source      String
  createdAt   DateTime @default(now())

  @@unique([userId, websiteUrl])
}
